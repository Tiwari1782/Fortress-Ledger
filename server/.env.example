# ============================================================================
# FortressLedger — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================================

PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=fortress_ledger

# JWT Secret — Generate a strong random string (min 64 characters)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
